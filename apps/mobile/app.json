{
  "expo": {
    "name": "inField",
    "slug": "infield",
    "version": "0.0.1",
    "orientation": "portrait",
    "scheme": "infield",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.infield.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FEFDFB"
      },
      "package": "com.infield.app"
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": ["expo-router", "expo-font", "expo-image", "expo-secure-store"]
  }
}
