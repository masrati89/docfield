{
  "expo": {
    "name": "DocField",
    "slug": "docfield",
    "version": "0.0.1",
    "orientation": "portrait",
    "scheme": "docfield",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.docfield.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FEFDFB"
      },
      "package": "com.docfield.app"
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-camera",
        {
          "cameraPermission": "DocField צריך גישה למצלמה כדי לתעד ליקויים."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "DocField צריך גישה לגלריה כדי לבחור תמונות של ליקויים."
        }
      ]
    ]
  }
}
