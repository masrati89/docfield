# ============================================================
# .env.seed.local — LOCAL DEVELOPMENT ONLY — DO NOT USE IN PROD
# ============================================================
# Copy this file to `scripts/.env.seed.local` (which is gitignored)
# and fill in the values from `npx supabase status` output.
#
# The seed script (scripts/seed.mjs) refuses to run unless:
#   1. SUPABASE_URL points to 127.0.0.1 or localhost
#   2. SUPABASE_SECRET_KEY starts with `sb_secret_` (new key format)
#   3. NODE_ENV is not `production`
#
# Never commit .env.seed.local to git.
# ============================================================

# Local Supabase API URL (from `supabase status` → "API URL")
SUPABASE_URL=http://127.0.0.1:54321

# Local Supabase Secret Key (from `supabase status` → "Secret key")
# Uses the new format: `sb_secret_...` — NOT the legacy JWT
# service_role_key format.
SUPABASE_SECRET_KEY=sb_secret_REPLACE_ME

# Credentials for the seed admin user (local only)
SEED_ADMIN_EMAIL=admin@infield.local
SEED_ADMIN_PASSWORD=Infield2026!
